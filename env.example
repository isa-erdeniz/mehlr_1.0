# mehlr_1.0 — Örnek ortam değişkenleri. Bu dosyayı .env olarak kopyalayın.
SECRET_KEY=your-django-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
GEMINI_API_KEY=your_gemini_api_key_here
MEHLR_RATE_LIMIT=15
MEHLR_CACHE_TTL=300
MEHLR_MAX_CONVERSATION_HISTORY=20

# Railway / Production
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app
CSRF_TRUSTED_ORIGINS=https://your-app.railway.app,http://localhost:8000

# Production (PostgreSQL + Redis)
DATABASE_URL=postgresql://user:pass@localhost:5432/mehlr_db
REDIS_URL=redis://127.0.0.1:6379/1
MEHLR_PRIMARY_MODEL=gemini-2.5-flash
MEHLR_FALLBACK_MODEL=gemini-2.5-flash
MEHLR_LOG_LEVEL=INFO
